# ── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ── Base de datos ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://sotang:sotang_dev_pass@localhost:5432/sotang_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 64
JWT_SECRET=cambia-esto-por-una-clave-secreta-muy-larga
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=30

# ── Resend (email) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=notificaciones@tudominio.com

# ── Telegram Bot ───────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=xxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_WEBHOOK_SECRET=cambia-esto

# ── CoinGecko ─────────────────────────────────────────────────────────────────
COINGECKO_API_KEY=

# ── Google Drive (service account para backups) ───────────────────────────────
GDRIVE_SERVICE_ACCOUNT_JSON=./secrets/gdrive-service-account.json
GDRIVE_BACKUP_FOLDER_ID=

# ── Firebase (push notifications) ─────────────────────────────────────────────
FIREBASE_CREDENTIALS_JSON=./secrets/firebase-credentials.json

# ── Internal ──────────────────────────────────────────────────────────────────
# Clave compartida entre sotang-bot y sotang-api (solo red interna)
INTERNAL_API_KEY=cambia-esto-tambien
