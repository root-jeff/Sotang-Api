# ── Base de datos ──────────────────────────────────────────────────────────────
# Formato: postgresql+psycopg2://usuario:password@host:puerto/nombre_db
DATABASE_URL=postgresql+psycopg2://sotang:password@localhost:5432/sotang_db

# ── JWT ────────────────────────────────────────────────────────────────────────
SECRET_KEY=cambia-esto-por-una-clave-secreta-muy-larga
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Resend (email) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=notificaciones@raas-xtr.online

# ── Telegram Bot ───────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=xxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── CoinGecko ─────────────────────────────────────────────────────────────────
COINGECKO_API_KEY=

# ── Google Drive (service account para backups) ───────────────────────────────
GDRIVE_SERVICE_ACCOUNT_JSON=./secrets/gdrive-service-account.json
GDRIVE_BACKUP_FOLDER_ID=

# ── Firebase (push notifications) ─────────────────────────────────────────────
FIREBASE_CREDENTIALS_JSON=./secrets/firebase-credentials.json

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
